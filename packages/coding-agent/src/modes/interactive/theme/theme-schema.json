{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Pi Coding Agent Theme",
	"description": "Pi 编码代理的主题模式",
	"type": "object",
	"required": ["name", "colors"],
	"properties": {
		"$schema": {
			"type": "string",
			"description": "JSON 模式引用"
		},
		"name": {
			"type": "string",
			"description": "主题名称"
		},
		"vars": {
			"type": "object",
			"description": "可复用颜色变量",
			"additionalProperties": {
				"oneOf": [
					{
						"type": "string",
						"description": "十六进制颜色(#RRGGBB)、变量引用或空字符串（使用终端默认）"
					},
					{
						"type": "integer",
						"minimum": 0,
						"maximum": 255,
						"description": "256 色调色板索引（0-255）"
					}
				]
			}
		},
		"colors": {
			"type": "object",
			"description": "主题颜色定义（全部必需）",
			"required": [
				"accent",
				"border",
				"borderAccent",
				"borderMuted",
				"success",
				"error",
				"warning",
				"muted",
				"dim",
				"text",
				"thinkingText",
				"selectedBg",
				"userMessageBg",
				"userMessageText",
				"customMessageBg",
				"customMessageText",
				"customMessageLabel",
				"toolPendingBg",
				"toolSuccessBg",
				"toolErrorBg",
				"toolTitle",
				"toolOutput",
				"mdHeading",
				"mdLink",
				"mdLinkUrl",
				"mdCode",
				"mdCodeBlock",
				"mdCodeBlockBorder",
				"mdQuote",
				"mdQuoteBorder",
				"mdHr",
				"mdListBullet",
				"toolDiffAdded",
				"toolDiffRemoved",
				"toolDiffContext",
				"syntaxComment",
				"syntaxKeyword",
				"syntaxFunction",
				"syntaxVariable",
				"syntaxString",
				"syntaxNumber",
				"syntaxType",
				"syntaxOperator",
				"syntaxPunctuation",
				"thinkingOff",
				"thinkingMinimal",
				"thinkingLow",
				"thinkingMedium",
				"thinkingHigh",
				"thinkingXhigh",
				"bashMode"
			],
			"properties": {
				"accent": {
					"$ref": "#/$defs/colorValue",
					"description": "主要强调色（徽标、选中项、光标）"
				},
				"border": {
					"$ref": "#/$defs/colorValue",
					"description": "普通边框"
				},
				"borderAccent": {
					"$ref": "#/$defs/colorValue",
					"description": "高亮边框"
				},
				"borderMuted": {
					"$ref": "#/$defs/colorValue",
					"description": "柔和边框"
				},
				"success": {
					"$ref": "#/$defs/colorValue",
					"description": "成功状态"
				},
				"error": {
					"$ref": "#/$defs/colorValue",
					"description": "错误状态"
				},
				"warning": {
					"$ref": "#/$defs/colorValue",
					"description": "警告状态"
				},
				"muted": {
					"$ref": "#/$defs/colorValue",
					"description": "次要/暗淡文本"
				},
				"dim": {
					"$ref": "#/$defs/colorValue",
					"description": "极暗文本（比柔和更淡）"
				},
				"text": {
					"$ref": "#/$defs/colorValue",
					"description": "默认文本颜色（通常为空字符串）"
				},
				"thinkingText": {
					"$ref": "#/$defs/colorValue",
					"description": "思考块文本颜色"
				},
				"selectedBg": {
					"$ref": "#/$defs/colorValue",
					"description": "选中项背景"
				},
				"userMessageBg": {
					"$ref": "#/$defs/colorValue",
					"description": "用户消息背景"
				},
				"userMessageText": {
					"$ref": "#/$defs/colorValue",
					"description": "用户消息文本颜色"
				},
				"customMessageBg": {
					"$ref": "#/$defs/colorValue",
					"description": "自定义消息背景（钩子注入的消息）"
				},
				"customMessageText": {
					"$ref": "#/$defs/colorValue",
					"description": "自定义消息文本颜色"
				},
				"customMessageLabel": {
					"$ref": "#/$defs/colorValue",
					"description": "自定义消息类型标签颜色"
				},
				"toolPendingBg": {
					"$ref": "#/$defs/colorValue",
					"description": "工具执行框（待处理状态）"
				},
				"toolSuccessBg": {
					"$ref": "#/$defs/colorValue",
					"description": "工具执行框（成功状态）"
				},
				"toolErrorBg": {
					"$ref": "#/$defs/colorValue",
					"description": "工具执行框（错误状态）"
				},
				"toolTitle": {
					"$ref": "#/$defs/colorValue",
					"description": "工具执行框标题颜色"
				},
				"toolOutput": {
					"$ref": "#/$defs/colorValue",
					"description": "工具执行框输出文本颜色"
				},
				"mdHeading": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 标题文本"
				},
				"mdLink": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 链接文本"
				},
				"mdLinkUrl": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 链接 URL"
				},
				"mdCode": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 行内代码"
				},
				"mdCodeBlock": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 代码块内容"
				},
				"mdCodeBlockBorder": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 代码块边框"
				},
				"mdQuote": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 引用文本"
				},
				"mdQuoteBorder": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 引用边框"
				},
				"mdHr": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 水平分割线"
				},
				"mdListBullet": {
					"$ref": "#/$defs/colorValue",
					"description": "Markdown 列表符号/编号"
				},
				"toolDiffAdded": {
					"$ref": "#/$defs/colorValue",
					"description": "工具差异中的新增行"
				},
				"toolDiffRemoved": {
					"$ref": "#/$defs/colorValue",
					"description": "工具差异中的删除行"
				},
				"toolDiffContext": {
					"$ref": "#/$defs/colorValue",
					"description": "工具差异中的上下文行"
				},
				"syntaxComment": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：注释"
				},
				"syntaxKeyword": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：关键字"
				},
				"syntaxFunction": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：函数名"
				},
				"syntaxVariable": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：变量名"
				},
				"syntaxString": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：字符串字面量"
				},
				"syntaxNumber": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：数字字面量"
				},
				"syntaxType": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：类型名"
				},
				"syntaxOperator": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：运算符"
				},
				"syntaxPunctuation": {
					"$ref": "#/$defs/colorValue",
					"description": "语法高亮：标点符号"
				},
				"thinkingOff": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：关闭"
				},
				"thinkingMinimal": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：最低"
				},
				"thinkingLow": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：低"
				},
				"thinkingMedium": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：中"
				},
				"thinkingHigh": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：高"
				},
				"thinkingXhigh": {
					"$ref": "#/$defs/colorValue",
					"description": "思考级别边框：最高（仅限 OpenAI codex-max）"
				},
				"bashMode": {
					"$ref": "#/$defs/colorValue",
					"description": "Bash 模式编辑器边框颜色"
				}
			},
			"additionalProperties": false
		},
		"export": {
			"type": "object",
			"description": "用于 HTML 导出的可选颜色（未指定时默认继承自用户消息背景）",
			"properties": {
				"pageBg": {
					"$ref": "#/$defs/colorValue",
					"description": "页面背景色"
				},
				"cardBg": {
					"$ref": "#/$defs/colorValue",
					"description": "卡片/容器背景色"
				},
				"infoBg": {
					"$ref": "#/$defs/colorValue",
					"description": "信息区域背景（系统提示、通知）"
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false,
	"$defs": {
		"colorValue": {
			"oneOf": [
				{
					"type": "string",
					"description": "十六进制颜色(#RRGGBB)、变量引用或空字符串（使用终端默认）"
				},
				{
					"type": "integer",
					"minimum": 0,
					"maximum": 255,
					"description": "256 色调色板索引（0-255）"
				}
			]
		}
	}
}
